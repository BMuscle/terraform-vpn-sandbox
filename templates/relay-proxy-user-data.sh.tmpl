#!/bin/bash
set -euo pipefail

%{ if bootstrap_enabled ~}
dnf install -y nginx

cat >/etc/nginx/conf.d/relay-proxy.conf <<'NGINX_CONF'
server {
  listen 80;
  server_name ${site_to_service_domain};

  location / {
    proxy_pass http://${service_nlb_dns_name};
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}

server {
  listen 80 default_server;
  server_name _;

  location / {
    proxy_pass http://${site_web_private_ip};
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
NGINX_CONF

nginx -t
systemctl enable --now nginx
systemctl restart nginx
%{ else ~}
echo "relay proxy bootstrap skipped" >/var/log/relay-proxy-bootstrap.log
%{ endif ~}
